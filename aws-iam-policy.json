{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SkillLinkS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::courses-skilllearn",
        "arn:aws:s3:::courses-skilllearn/*"
      ]
    },
    {
      "Sid": "SkillLinkS3PresignedUrls",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::courses-skilllearn/*"
      ]
    }
  ]
}
